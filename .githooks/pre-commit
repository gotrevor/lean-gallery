#!/usr/bin/env bash

# Chain the global guard (protected-branch, whitespace, non-ascii) FIRST — a repo-local
# core.hooksPath REPLACES the global hooks (single-valued), so it must be called explicitly.
# Per-repo opt-out when main IS the working branch: git config hooks.allowDirectMain true
"$HOME/home/.git-templates/hooks/pre-commit" || exit 1
# LeanGallery green-gate: a commit that touches Lean/build files must `lake build` clean.
#
# This repo runs a PR flow (branch → PR → merge), so the chained protected-branch
# guard above stays ACTIVE here — direct commits on main are refused. (It once was
# dropped as "main is the working branch"; that led to a main-divergence on 2026-07-05.)
#
# Enable on a fresh clone (core.hooksPath is local config, NOT tracked):
#     git config core.hooksPath .githooks
set -euo pipefail

# --no-renames so a rename emits its two literal paths (old + new) and is not skipped.
changed=$(git diff --cached --name-only --no-renames)

if printf '%s\n' "$changed" | grep -qE '\.lean$|lakefile\.(toml|lean)$|lake-manifest\.json$|^lean-toolchain$'; then
  echo "lean-gallery pre-commit: lake build…"
  if ! lake build; then
    echo "❌ lake build failed — commit aborted (fix or use 'git commit --no-verify' to override)." >&2
    exit 1
  fi
  echo "✅ build green."
fi
